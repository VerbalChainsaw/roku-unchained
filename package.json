{
  "name": "roku-toolkit",
  "version": "1.0.0",
  "description": "Complete Roku Dev Toolkit + Stream Proxy — hardware freedom suite",
  "main": "server.js",
  "scripts": {
    "start": "pwsh -File start.ps1",
    "stop": "pwsh -Command \"Get-NetTCPConnection -LocalPort (4700..4710+9090..9099) -EA 0 | ForEach { Stop-Process -Id `$_.OwningProcess -Force -EA 0 }; Write-Host 'Stopped'\"",
    "dev": "node server.js",
    "scan": "node -e \"const s=require('./lib/scanner');s.discover().then(devices=>console.log(JSON.stringify(devices,null,2)))\"",
    "ecp": "node -e \"const e=require('./lib/ecp');const c=new e.ECPClient(process.argv[2]);c.deviceInfo().then(d=>console.log(JSON.stringify(d,null,2)))\"",
    "test": "node tests/verify.js"
  },
  "dependencies": {
    "express": "^4.18.2",
    "ws": "^8.16.0",
    "http-proxy": "^1.18.1",
    "fast-xml-parser": "^4.3.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "eslint": "^8.56.0"
  },
  "keywords": ["roku", "ecp", "stream-proxy", "dev-tools", "sideload"],
  "license": "MIT",
  "author": "Gabriel"
}
