# Roku Dev Toolkit Configuration
# Copy this to .env and customize

# ─── Server Settings ─────────────────────────────────────────────
TOOLKIT_PORT=4700
TOOLKIT_HOST=127.0.0.1

# ─── Stream Proxy ────────────────────────────────────────────────
STREAM_PROXY_PORT=9090
STREAM_PROXY_HOST=0.0.0.0
RECORD_DIR=./data/recordings
MAX_RECORD_MB=500
LOG_STREAMS=true

# ─── MITM Proxy ──────────────────────────────────────────────────
MITM_PORT=8888
MITM_HOST=0.0.0.0

# ─── Roku Bridge ─────────────────────────────────────────────────
# Your PC's IP that the Roku should connect to
ROKU_TARGET_HOST=192.168.1.100
ROKU_BRIDGE_PORT=4701

# ─── Discovery ───────────────────────────────────────────────────
AUTO_DISCOVER_INTERVAL=60000
